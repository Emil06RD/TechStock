<!DOCTYPE html>
<html lang="es">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{title}}</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
  <link rel="stylesheet" href="/css/style.css">
</head>

<body>
  <div class="ts-login-page">
    <div class="ts-login-card">


      <div class="ts-login-header">
        <span class="ts-login-logo">🖥️</span>
        <h1 class="ts-login-app-name">TechStock</h1>
        <p class="ts-login-subtitle">Sistema de Gestión de Inventario</p>
      </div>

      <div class="ts-login-body">

        {{#if error}}
        <div class="ts-alert ts-alert-danger" id="loginError" role="alert">
          ⚠️ {{error}}
        </div>
        {{/if}}

        <form action="/login" method="POST" id="loginForm" novalidate>
          <div class="mb-3">
            <label for="username" class="form-label">Usuario</label>
            <input type="text" class="form-control" id="username" name="username" placeholder="Ingresa tu usuario"
              autocomplete="username" required>
          </div>

          <div class="mb-4">
            <label for="password" class="form-label">Contraseña</label>
            <input type="password" class="form-control" id="password" name="password"
              placeholder="Ingresa tu contraseña" autocomplete="current-password" required>
          </div>

          <button type="submit" class="ts-login-submit" id="loginBtn">
            Iniciar Sesión
          </button>
        </form>

        <div class="ts-login-hint">
          <strong>Credenciales de prueba:</strong><br>
          Usuario: <code>admin</code> &nbsp;|&nbsp; Contraseña: <code>admin123</code>
        </div>
      </div>

    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/js/login.js"></script>
</body>

</html>